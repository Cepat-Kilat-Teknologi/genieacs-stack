# =============================================================================
# GenieACS Stack -- Environment Configuration
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:          cp .env.example .env
#   2. Replace every placeholder value (search for "REPLACE_ME").
#   3. Start the stack:         make up-d
#   4. Create an admin user:    make create-user
#
# IMPORTANT: Never commit the real .env file. It is listed in .gitignore.
#
# For NBI API authentication, see: examples/nbi-auth/
# =============================================================================

# ===========================================
# SECURITY -- CHANGE THESE VALUES BEFORE FIRST RUN!
# ===========================================
# All secrets below ship with obvious placeholder values. The `make setup`
# target will warn you if any remain unchanged.

# JWT secret used to sign UI authentication tokens. A weak or default value
# lets anyone forge valid sessions. Must be at least 32 characters.
#   Generate with: openssl rand -hex 32
GENIEACS_UI_JWT_SECRET=REPLACE_ME--openssl-rand-hex-32

# Credentials for the initial admin user created by `make create-user`.
# These are only read by the provisioning script -- they are NOT baked into
# the running GenieACS container.
GENIEACS_ADMIN_USERNAME=admin
GENIEACS_ADMIN_PASSWORD=REPLACE_ME--strong-password

# ===========================================
# MONGODB AUTHENTICATION (REQUIRED)
# ===========================================
# MongoDB is configured with authentication enabled. The root credentials
# here are used both by the mongo container (to initialize the admin account)
# and by GenieACS (to connect). They MUST match.

# Root username for the MongoDB instance.
MONGO_INITDB_ROOT_USERNAME=admin

# Root password for the MongoDB instance. A weak password exposes all device
# management data. Generate a strong one:
#   openssl rand -base64 24
MONGO_INITDB_ROOT_PASSWORD=REPLACE_ME--openssl-rand-base64-24

# Full MongoDB connection URL consumed by all four GenieACS services.
# If you change the username or password above, update this URL to match.
# The "authSource=admin" parameter tells the driver to authenticate against
# the admin database where the root user was created.
GENIEACS_MONGODB_CONNECTION_URL=mongodb://admin:REPLACE_ME--openssl-rand-base64-24@mongo:27017/genieacs?authSource=admin

# ===========================================
# AUTHENTICATION SETTINGS
# ===========================================

# Whether the GenieACS web UI requires login. Disabling this removes all
# access control from the management interface -- only do so in isolated
# lab environments.
GENIEACS_UI_AUTH=true

# How long a JWT session token remains valid before the user must log in
# again. Commented out because the GenieACS default (usually 1 hour) is
# sensible; uncomment and adjust if your workflow needs longer sessions.
# GENIEACS_JWT_EXPIRES_IN=7d

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
# These ports are mapped by docker-compose onto the host. By default they
# bind to all interfaces (0.0.0.0). To restrict access to localhost only,
# prefix the port with 127.0.0.1 (e.g., GENIEACS_UI_PORT=127.0.0.1:3000).

# Commented out because the default (0.0.0.0) is set in the Compose file.
# Uncomment to override the listen address for all services at once.
# GENIEACS_HOST=0.0.0.0

# CWMP (TR-069) port -- CPE devices connect here for remote management.
GENIEACS_CWMP_PORT=7547
# NBI (Northbound Interface) port -- REST API used by external systems.
GENIEACS_NBI_PORT=7557
# FS (File Server) port -- serves firmware images and config files to CPEs.
GENIEACS_FS_PORT=7567
# UI port -- the web-based management dashboard.
GENIEACS_UI_PORT=3000

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# These are commented out because the defaults are appropriate for most
# deployments. Uncomment only if you understand the implications.

# Allow GenieACS to accept connections without TLS. Useful during
# development when you do not have certificates configured. Keep this
# disabled (false) in production to enforce encrypted transport.
# GENIEACS_ALLOW_INSECURE=false

# Enable verbose debug logging. Generates a large volume of output and may
# expose sensitive data in logs -- do not enable in production.
# GENIEACS_DEBUG=false