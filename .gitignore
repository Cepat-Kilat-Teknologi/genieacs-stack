# =============================================================================
# .gitignore -- GenieACS Stack
# =============================================================================
#
# Keeps secrets, build artifacts, and editor state out of version control.
# The .env.example template IS tracked so new contributors can bootstrap
# quickly; the real .env (containing production secrets) is excluded below.
# =============================================================================

# ---------------------------------------------------------------------------
# GenieACS-specific: environment files and secrets
# ---------------------------------------------------------------------------
# The .env file holds MongoDB passwords, JWT secrets, and admin credentials.
# .env.example is also ignored because it ships with placeholder secrets
# that should never be mistaken for real values in a repository diff.
.env
.env.local
.env.*.local
.env.example
.env.example.local

# TLS certificates, private keys, and credential files that may be added
# locally for HTTPS or NBI API authentication.
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets.json
.credentials
.secrets

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port

# ---------------------------------------------------------------------------
# Runtime data
# ---------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Coverage directories
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
lcov.info

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs
*.log

# ---------------------------------------------------------------------------
# Database files
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.realm

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
Thumbs.db
.AppleDouble
.LSOverride
._*

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
kubeconfig
.kube/

# ---------------------------------------------------------------------------
# Backups (generated by `make backup`, can be large binary blobs)
# ---------------------------------------------------------------------------
*.bak
*.backup
*~

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------
.local/
.tmp/

# ---------------------------------------------------------------------------
# Generated files
# ---------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo
